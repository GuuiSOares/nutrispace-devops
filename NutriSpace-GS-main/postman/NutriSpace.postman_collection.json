								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nomePlanta\": \"Alface Espacial v2\",\n  \"tempMinIdeal\": 18.0,\n  \"tempMaxIdeal\": 27.0,\n  \"umiMinIdeal\": 60.0\n}"
