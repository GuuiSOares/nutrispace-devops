{
	"info": {
		"_postman_id": "nutrispace-api-collection",
		"name": "NutriSpace API",
		"description": "Collection NutriSpace (FIAP GS).\n\n**Como testar:**\n1. Importe collection + environment (`NutriSpace-Local` ou `NutriSpace-Render`)\n2. Reinicie a API (perfil `oracle`)\n3. Run collection com **Delay 300ms** entre requisições\n4. Na 1ª execução após erro, **desmarque** Keep variable values\n\n**Login:** `lucas@nutrispace.com` / `senha123`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "idPlanta",
			"value": ""
		},
		{
			"key": "idAstronauta",
			"value": ""
		},
		{
			"key": "idAstronautaNovo",
			"value": ""
		},
		{
			"key": "idEstufa",
			"value": ""
		},
		{
			"key": "idReservatorio",
			"value": ""
		},
		{
			"key": "idAlerta",
			"value": ""
		},
		{
			"key": "emailAstronautaNovo",
			"value": ""
		}
	],
	"item": [
		{
			"name": "01 - Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Login OK', () => pm.response.to.have.status(200));",
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.collectionVariables.set('idAstronauta', json.idAstronauta);",
									"    pm.test('Token JWT recebido', () => pm.expect(json.token).to.be.a('string'));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"lucas@nutrispace.com\",\n  \"senha\": \"senha123\"\n}"
						},
						"url": "{{baseUrl}}/auth/login"
					}
				}
			]
		},
		{
			"name": "02 - Raiz HATEOAS",
			"item": [
				{
					"name": "GET / (links)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HATEOAS OK', () => pm.response.to.have.status(200));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"url": "{{baseUrl}}/"
					}
				}
			]
		},
		{
			"name": "03 - Plantas",
			"item": [
				{
					"name": "Listar plantas",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Listar plantas OK', () => pm.response.to.have.status(200));",
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json._embedded) {",
									"        const items = json._embedded[Object.keys(json._embedded)[0]];",
									"        if (items && items.length > 0 && items[0].idPlanta) {",
									"            pm.collectionVariables.set('idPlanta', items[0].idPlanta);",
									"        }",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/plantas"
					}
				},
				{
					"name": "Criar planta",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Criar planta OK', () => pm.response.to.have.status(201));",
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set('idPlanta', pm.response.json().idPlanta);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nomePlanta\": \"Alface Espacial\",\n  \"tempMinIdeal\": 18.0,\n  \"tempMaxIdeal\": 26.0,\n  \"umiMinIdeal\": 55.0\n}"
						},
						"url": "{{baseUrl}}/plantas"
					}
				},
				{
					"name": "Buscar planta por ID",
					"event": [
						{
							"listen": "test",
